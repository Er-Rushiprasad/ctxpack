{
  "manifest_version": 3,
  "name": "Context Packer",
  "version": "0.1.0",
  "description": "Pack the most relevant files from a local repo into a token-budgeted bundle for claude.ai.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "https://claude.ai/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
